{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "eggologic-dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["eggologic-app/node_modules/next/dist/bin/next", "dev", "eggologic-app"],
      "port": 3000
    },
    {
      "name": "eggologic-prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["eggologic-app/node_modules/next/dist/bin/next", "start", "eggologic-app"],
      "port": 3000
    },
    {
      "name": "eggologic-dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dashboard/node_modules/vite/bin/vite.js", "dashboard"],
      "port": 5173
    }
  ]
}
